generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OrganizationUnit {
  id        Int      @id @default(autoincrement())
  name      String
  type      UnitType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentId Int?
  parent   OrganizationUnit?  @relation("Hierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children OrganizationUnit[] @relation("Hierarchy")

  users                   User[]
  availableGrades         Grade[]
  organizationAssignments OrganizationAssignment[]

  @@index([parentId])
  @@index([type])
}

enum UnitType {
  STATE
  DISTRICT
  BLOCK
  SCHOOL
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  organizationUnitId Int?
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)

  gradeId Int?
  grade   Grade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)

  assignments  CourseAssignment[]
  quizAttempts QuizAttempt[]
  watchLogs    WatchLog[]

  @@index([organizationUnitId])
  @@index([gradeId])
  @@index([role])
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  courses Course[]
}

model SkillLevel {
  id      Int      @id @default(autoincrement())
  level   String   @unique
  courses Course[]
}

model Grade {
  id      Int                @id @default(autoincrement())
  value   String             @unique
  courses Course[]
  users   User[]
  schools OrganizationUnit[]
}

model Language {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  courses Course[]
}

model Tag {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  courses Course[] @relation("CourseTags")
}

model Course {
  id                      Int                      @id @default(autoincrement())
  title                   String
  description             String?
  createdBy               String?
  createdAt               DateTime                 @default(now())
  thumbnailUrl            String?
  category                Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId              Int?
  skillLevel              SkillLevel?              @relation(fields: [skillLevelId], references: [id], onDelete: SetNull)
  skillLevelId            Int?
  grade                   Grade?                   @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  gradeId                 Int?
  language                Language?                @relation(fields: [languageId], references: [id], onDelete: SetNull)
  languageId              Int?
  tags                    Tag[]                    @relation("CourseTags")
  assignments             CourseAssignment[]
  courseVideos            CourseVideo[]
  organizationAssignments OrganizationAssignment[]
}

model OrganizationAssignment {
  id                 Int      @id @default(autoincrement())
  courseId           Int
  organizationUnitId Int
  assignedAt         DateTime @default(now())
  assignedById       Int? // The admin who created this assignment

  course           Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)

  @@unique([courseId, organizationUnitId], name: "course_org_unique_assignment")
}

model CourseAssignment {
  id         Int      @id @default(autoincrement())
  courseId   Int
  userId     Int
  assignedAt DateTime
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId], name: "courseId_userId")
}

model CourseVideo {
  id       Int    @id @default(autoincrement())
  courseId Int
  videoId  Int
  order    Int
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  video    Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([courseId, videoId])
  @@index([courseId, order])
}

model Video {
  id           Int           @id @default(autoincrement())
  title        String
  platform     String
  videoUrl     String
  videoId      String        @unique
  duration     Int
  createdAt    DateTime
  thumbnailUrl String?
  description  String?
  courseVideos CourseVideo[]
  quiz         Quiz?
  watchLogs    WatchLog[]
}

model WatchLog {
  id                Int       @id @default(autoincrement())
  userId            Int
  videoId           Int
  totalWatchTime    Int
  isCompleted       Boolean   @default(false)
  watchedPercentage Float     @default(0.0)
  skipEvents        Json      @default("[]")
  pauseEvents       Json      @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video             Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  lastUpdateTime    DateTime?
  lastUserAgent     String?
  lastEventType     String?

  @@unique([userId, videoId])
  @@index([userId, updatedAt(sort: Desc)])
  @@index([videoId, isCompleted])
  @@index([userId, videoId])
  @@index([lastUpdateTime])
}

model Quiz {
  id          Int           @id @default(autoincrement())
  videoId     Int           @unique
  generatedBy String?
  createdAt   DateTime
  questions   Json
  video       Video         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  attempts    QuizAttempt[]
}

model QuizAttempt {
  id          Int      @id @default(autoincrement())
  userId      Int
  quizId      Int
  score       Float
  answers     Json?
  completedAt DateTime
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPERADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}
